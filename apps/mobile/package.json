{
  "name": "@tronbrowser/mobile",
  "version": "3.8.0",
  "private": true,
  "description": "TronBrowser mobile companion (Expo / React Native) — browser · AI chat · agents",
  "main": "index.js",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint . --ext .ts,.tsx",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "export": "expo export --platform all",
    "prebuild": "expo prebuild"
  },
  "dependencies": {
    "expo": "^57.0.1",
    "expo-constants": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-webview": "13.16.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.2.17",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
