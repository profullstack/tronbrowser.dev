{
  "name": "@tronbrowser/mobile",
  "version": "0.3.0",
  "private": true,
  "description": "TronBrowser mobile (Expo / React Native) — Phase 2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src",
    "_comment": "Phase 2: run `pnpm add expo react react-native expo-status-bar` then use the scripts below.",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
