#!/bin/sh
# TronBrowser launcher.
#
# TronBrowser is de-googled. Until the native Ungoogled-Chromium fork binary is
# bundled, this shim runs an Ungoogled Chromium / Chromium on the system (NEVER
# Google Chrome) in an ISOLATED TronBrowser profile with the AI sidebar and
# privacy flags. `tron <url>` passes URLs through.
# Override the browser with $TRONBROWSER_BROWSER=/path/to/binary.
set -eu

# Resolve our own real directory (we're usually invoked via a symlink).
SELF="$0"
while [ -L "$SELF" ]; do
  link="$(readlink "$SELF")"
  case "$link" in
    /*) SELF="$link" ;;
    *)  SELF="$(dirname "$SELF")/$link" ;;
  esac
done
DIR="$(CDPATH= cd -- "$(dirname -- "$SELF")" && pwd)"
EXTBASE_SRC="$DIR/extensions"   # holds ai-sidebar + chromium-web-store

BROWSER=""        # a binary path, or "flatpak"
FLATPAK_APP=""
IS_SNAP=0

if [ -n "${TRONBROWSER_BROWSER:-}" ]; then
  BROWSER="$TRONBROWSER_BROWSER"
elif [ -x "$DIR/chrome" ]; then
  BROWSER="$DIR/chrome"            # future: bundled native fork binary
else
  # De-googled binaries only — NO google-chrome. Prefer non-snap.
  snap_fallback=""
  for c in ungoogled-chromium ungoogled-chromium-stable chromium chromium-browser; do
    p="$(command -v "$c" 2>/dev/null)" || continue
    case "$p" in
      /snap/*) [ -z "$snap_fallback" ] && snap_fallback="$p" ;;
      *) BROWSER="$p"; break ;;
    esac
  done
  # Flatpak Ungoogled Chromium (Flathub) — a fully de-googled option.
  if [ -z "$BROWSER" ] && command -v flatpak >/dev/null 2>&1; then
    for app in io.github.ungoogled_software.ungoogled_chromium com.github.Eloston.UngoogledChromium; do
      if flatpak info "$app" >/dev/null 2>&1; then BROWSER="flatpak"; FLATPAK_APP="$app"; break; fi
    done
  fi
  [ -z "$BROWSER" ] && [ -n "$snap_fallback" ] && { BROWSER="$snap_fallback"; IS_SNAP=1; }
fi

# macOS app bundles (de-googled only).
if [ -z "$BROWSER" ]; then
  for app in \
    "/Applications/Ungoogled Chromium.app/Contents/MacOS/Chromium" \
    "/Applications/Chromium.app/Contents/MacOS/Chromium"; do
    if [ -x "$app" ]; then BROWSER="$app"; break; fi
  done
fi

if [ -z "$BROWSER" ]; then
  cat >&2 <<MSG
TronBrowser is de-googled and needs Ungoogled Chromium (it will NOT run Google Chrome).
Install one of:
  flatpak install -y flathub io.github.ungoogled_software.ungoogled_chromium
  # or your distro's 'ungoogled-chromium' / 'chromium' package
Then run 'tron' again. (Force a specific binary with TRONBROWSER_BROWSER=/path/to/browser.)
MSG
  exit 1
fi

# Profile + extension paths. Snap-confined browsers can only read NON-hidden
# files in \$HOME, so under snap use a visible profile dir and stage extensions.
if [ "$IS_SNAP" = "1" ]; then
  DATA="${TRONBROWSER_DATA:-$HOME/TronBrowser}"
  mkdir -p "$DATA"
  rm -rf "$DATA/extensions"; cp -R "$EXTBASE_SRC" "$DATA/extensions"
  EXTBASE="$DATA/extensions"
else
  DATA="${TRONBROWSER_DATA:-$HOME/.tronbrowser}"
  EXTBASE="$EXTBASE_SRC"
fi

# Load every bundled extension (each subdir with a manifest.json).
EXT=""
for d in "$EXTBASE"/*/; do
  [ -f "${d}manifest.json" ] && EXT="${EXT:+$EXT,}${d%/}"
done

# Warn loudly when the chosen browser isn't a de-googled Ungoogled Chromium.
case "$BROWSER" in
  *ungoogled*) ;;                      # ideal
  flatpak) ;;                          # flatpak ungoogled
  *)
    echo "TronBrowser: running '$BROWSER' — this is regular Chromium, NOT de-googled." >&2
    echo "  For a fully de-googled browser, install Ungoogled Chromium:" >&2
    echo "    flatpak install -y flathub io.github.ungoogled_software.ungoogled_chromium" >&2
    [ "$IS_SNAP" = "1" ] && echo "  (snap confinement also blocks an isolated TronBrowser profile — a non-snap browser is recommended.)" >&2
    ;;
esac

FLAGS="--user-data-dir=$DATA --class=TronBrowser --no-first-run --no-default-browser-check --no-pings --disable-background-networking --disable-breakpad --disable-domain-reliability --disable-sync --disable-features=Translate,OptimizationHints,InterestFeedContentSuggestions --load-extension=$EXT"

if [ "$BROWSER" = "flatpak" ]; then
  # shellcheck disable=SC2086
  exec flatpak run --filesystem="$DATA" --filesystem="$EXT_SRC" "$FLATPAK_APP" $FLAGS "$@"
else
  # shellcheck disable=SC2086
  exec "$BROWSER" $FLAGS "$@"
fi
