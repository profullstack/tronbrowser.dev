#!/bin/sh
# TronBrowser launcher.
#
# Until the native Ungoogled-Chromium fork binary is bundled, this shim runs a
# Chromium-family browser found on the system in an ISOLATED TronBrowser profile
# with the AI sidebar extension and TronBrowser's privacy flags. `tron <url>`
# passes URLs through. Same flags as apps/desktop/src/chromium-flags.ts.
set -eu

# Resolve our own real directory (we're usually invoked via a symlink).
SELF="$0"
while [ -L "$SELF" ]; do
  link="$(readlink "$SELF")"
  case "$link" in
    /*) SELF="$link" ;;
    *)  SELF="$(dirname "$SELF")/$link" ;;
  esac
done
DIR="$(CDPATH= cd -- "$(dirname -- "$SELF")" && pwd)"

EXT_SRC="$DIR/extensions/ai-sidebar"

# A bundled native binary (future) takes priority.
BROWSER=""
IS_SNAP=0
if [ -x "$DIR/chrome" ]; then
  BROWSER="$DIR/chrome"
else
  # Prefer a NON-snap browser: snap confinement can't read ~/.tronbrowser or the
  # extension under a hidden dir, so it would ignore our profile and just open
  # the default session. Remember a snap as a last resort.
  snap_fallback=""
  for c in ungoogled-chromium chromium chromium-browser google-chrome-stable google-chrome brave-browser brave; do
    p="$(command -v "$c" 2>/dev/null)" || continue
    case "$p" in
      /snap/*) [ -z "$snap_fallback" ] && snap_fallback="$p" ;;
      *) BROWSER="$p"; break ;;
    esac
  done
  if [ -z "$BROWSER" ] && [ -n "$snap_fallback" ]; then
    BROWSER="$snap_fallback"; IS_SNAP=1
  fi
fi

# macOS app bundles.
if [ -z "$BROWSER" ]; then
  for app in \
    "/Applications/Ungoogled Chromium.app/Contents/MacOS/Chromium" \
    "/Applications/Chromium.app/Contents/MacOS/Chromium" \
    "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
    "/Applications/Brave Browser.app/Contents/MacOS/Brave Browser"; do
    if [ -x "$app" ]; then BROWSER="$app"; break; fi
  done
fi

if [ -z "$BROWSER" ]; then
  echo "TronBrowser: no Chromium-family browser found." >&2
  echo "Install ungoogled-chromium (preferred) or chromium and retry." >&2
  exit 1
fi

# Profile + extension paths. Snap-confined browsers can only read NON-hidden
# files in $HOME, so under snap we use a visible profile dir and stage the
# extension there; otherwise we keep the hidden ~/.tronbrowser.
if [ "$IS_SNAP" = "1" ]; then
  DATA="${TRONBROWSER_DATA:-$HOME/TronBrowser}"
  mkdir -p "$DATA"
  rm -rf "$DATA/ai-sidebar"
  cp -R "$EXT_SRC" "$DATA/ai-sidebar"
  EXT="$DATA/ai-sidebar"
else
  DATA="${TRONBROWSER_DATA:-$HOME/.tronbrowser}"
  EXT="$EXT_SRC"
fi

exec "$BROWSER" \
  --user-data-dir="$DATA" \
  --class=TronBrowser \
  --no-first-run \
  --no-default-browser-check \
  --no-pings \
  --disable-background-networking \
  --disable-breakpad \
  --disable-domain-reliability \
  --disable-sync \
  --disable-features=Translate,OptimizationHints,InterestFeedContentSuggestions \
  --load-extension="$EXT" \
  "$@"
