{
  "name": "@tronbrowser/api",
  "version": "0.1.17",
  "private": true,
  "description": "TronBrowser auth + settings-sync API (CoinPay OAuth + email/password)",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
