    "lint": "echo \"[lint] api: stub\"",
    "start": "node dist/index.js",
    "migrate": "node ../../scripts/db-migrate.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@libsql/client": "^0.14.0",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
