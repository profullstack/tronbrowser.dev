<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>tronbrowser</id>
    <version>0.1.0</version>
    <title>TronBrowser</title>
    <authors>Profullstack, Inc.</authors>
    <projectUrl>https://tronbrowser.dev</projectUrl>
    <licenseUrl>https://github.com/profullstack/tronbrowser.dev/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <projectSourceUrl>https://github.com/profullstack/tronbrowser.dev</projectSourceUrl>
    <tags>browser chromium privacy ungoogled ai</tags>
    <summary>Open-source, privacy-first, AI-native browser (Ungoogled Chromium fork).</summary>
    <description>TronBrowser is an open-source, privacy-first, AI-native web browser built on Ungoogled Chromium. No telemetry, no ads, no sponsored tabs. Bring your own AI keys.</description>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
